{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "Excel_AI_chatbot_project/wsgi.py": {
      "maxDuration": 30
    }
  },
  "builds": [
    { "src": "manage.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "Excel_AI_chatbot_project/wsgi.py" }
  ]
}